{
  "name": "aventuras",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "Aventuras — cross-platform app (Expo on mobile, Electron on desktop).",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:start": "electron electron/dist/main.js",
    "desktop": "concurrently -k -n expo,electron -c blue,magenta \"expo start --web --port 8081\" \"wait-on http://localhost:8081 && pnpm electron:compile && pnpm electron:start\"",
    "build:web": "expo export --platform web",
    "build:desktop": "pnpm build:web && pnpm electron:compile && electron-builder",
    "build:desktop:linux": "pnpm build:web && pnpm electron:compile && electron-builder --linux",
    "build:desktop:mac": "pnpm build:web && pnpm electron:compile && electron-builder --mac",
    "build:desktop:win": "pnpm build:web && pnpm electron:compile && electron-builder --win"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "~19.1.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.aventuras.app",
    "productName": "Aventuras",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "electron/dist/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/dist/main.js"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    }
  },
  "private": true,
  "author": {
    "name": "Failerko",
    "email": "20503476+failerko@users.noreply.github.com",
    "url": "https://github.com/AventurasTeam"
  },
  "homepage": "https://github.com/AventurasTeam"
}
